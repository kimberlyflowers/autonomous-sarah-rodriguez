# BLOOM Letta Server - Environment Configuration
# Copy to .env and configure for Railway deployment

# Server Configuration
LETTA_SERVER_PORT=8283
LETTA_SERVER_HOST=0.0.0.0
LETTA_DEBUG=false

# PostgreSQL Database (Railway - same as heartbeat engine)
LETTA_PG_URI=postgresql://postgres:your_postgres_password_here@postgres.railway.internal:5432/bloom_heartbeat

# Alternative individual settings
LETTA_PG_HOST=postgres.railway.internal
LETTA_PG_PORT=5432
LETTA_PG_USER=postgres
LETTA_PG_PASSWORD=your_postgres_password_here
LETTA_PG_DATABASE=bloom_heartbeat

# Memory Configuration
LETTA_MEMORY_BACKEND=postgresql
LETTA_CHUNK_SIZE=1000
LETTA_OVERLAP_SIZE=200

# API Configuration
LETTA_API_KEY_REQUIRED=false
LETTA_CORS_ENABLED=true

# Logging
LETTA_LOG_LEVEL=INFO
LETTA_LOG_FORMAT=json

# Agent Configuration
DEFAULT_AGENT_MEMORY_SIZE=6000
DEFAULT_AGENT_CONTEXT_WINDOW=12000

# Performance
LETTA_CACHE_ENABLED=true
LETTA_CACHE_SIZE=1000
LETTA_BACKGROUND_TASKS=true

# Railway Specific
PORT=8283
RAILWAY_STATIC_URL=
RAILWAY_PUBLIC_DOMAIN=