# WaveSpeed AI API Key - Get from https://wavespeed.ai/accesskey
WAVESPEED_API_KEY=your_api_key_here

# Optional: comma-separated list of API keys that authorize REST /api/* requests.
# When unset, all requests are allowed (single-tenant / dev mode).
# When set, MCP connectors and Bloomies must send X-API-Key: <one_of_these>
UGC_API_KEYS=

# Server port (Railway sets this automatically)
PORT=8080

# Log level
LOG_LEVEL=info

# RunPod public/serverless endpoints
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_WAN22_ENDPOINT_ID=t3hfdqexn97qtz
RUNPOD_WAN_ANIMATE_ENDPOINT_ID=ep01saywf3pgor
RUNPOD_MEIGEN_ENDPOINT_ID=infinitetalk
RUNPOD_FASTER_WHISPER_ENDPOINT_ID=

# Optional endpoint-specific keys/URLs override RUNPOD_API_KEY / endpoint IDs.
RUNPOD_WAN22_API_KEY=
RUNPOD_WAN22_ENDPOINT_URL=
RUNPOD_WAN_ANIMATE_API_KEY=
RUNPOD_WAN_ANIMATE_ENDPOINT_URL=
RUNPOD_FASTER_WHISPER_API_KEY=
RUNPOD_FASTER_WHISPER_ENDPOINT_URL=
