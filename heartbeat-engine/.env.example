# BLOOM Heartbeat Engine - Environment Configuration
# Copy to .env and fill in your values

# Agent Configuration
AGENT_ID=bloomie-sarah-rodriguez
AGENT_NAME=Sarah Rodriguez
AUTONOMY_LEVEL=1

# LLM Configuration — Model-Agnostic (at least one API key required)
# Primary model — set to any supported model string:
#   Claude:   claude-haiku-4-5-20251001, claude-sonnet-4-5-20250929, claude-opus-4-5-20250414
#   GPT:      gpt-4o, gpt-4o-mini, gpt-4-turbo
#   Gemini:   gemini-2.5-flash, gemini-2.0-flash
#   DeepSeek: deepseek-chat, deepseek-reasoner
# Failover chain: primary → next available provider → next → error
LLM_MODEL=claude-sonnet-4-5-20250929

# API Keys — add keys for each provider you want available (failover uses these)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# PostgreSQL Database (Railway)
DATABASE_URL=postgresql://postgres:your_postgres_password_here@postgres.railway.internal:5432/bloom_heartbeat
PGHOST=postgres.railway.internal
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_postgres_password_here
PGDATABASE=bloom_heartbeat

# Letta Memory Server
LETTA_SERVER_URL=http://letta-server.railway.internal:8283

# GoHighLevel Integration
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=iGy4nrpDVU0W1jAvseL3
GHL_BLOG_ID=DHQrtpkQ3Cp7c96FCyDu

# Human Contact (Required for escalations)
HUMAN_CONTACT_NAME=Kimberly Flowers
HUMAN_CONTACT_EMAIL=kimberly@bloomiestaffing.com
HUMAN_CONTACT_PHONE=
HUMAN_GHL_USER_ID=

# Email Configuration (Optional - for SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=sarah@bloomiestaffing.com
FROM_NAME=Sarah Rodriguez

# Supabase Backup (Optional)
SUPABASE_URL=https://njfhzabmaxhfzekbzpzz.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# n8n Integration (Already configured on Railway)
N8N_WEBHOOK_URL=https://primary-production-52e9.up.railway.app

# Operational Settings
TIMEZONE=America/New_York
LOG_LEVEL=info
NODE_ENV=production
PORT=3000

# Notification Settings
NOTIFICATION_EMAIL=notifications@bloomiestaffing.com
DEFAULT_CALENDAR_ID=